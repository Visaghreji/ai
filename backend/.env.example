# Backend environment variables
# Set LLM_PROVIDER to 'ollama' (default) or 'openai' (for cloud APIs like OpenRouter, Groq, Gemini)
LLM_PROVIDER=ollama

# Set OLLAMA_HOST if using a remote Ollama server.
OLLAMA_HOST=http://localhost:11434

# OpenAI-compatible API configurations (used when LLM_PROVIDER=openai)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-3.5-turbo

# Optional: Tavily API key for web search support
TAVILY_API_KEY=

# Optional: override embedding model name if needed
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_MODEL_LOCAL_PATH=
